# Cache-Control headers (Netlify) — cut repeat-visit bandwidth so the free tier isn't blown.
# The 1.9 MB 3D model + fonts are effectively static → cache hard. JS gets a short cache
# so edits still propagate within the hour. HTML + data stay fresh (data.json is fetched
# from GitHub raw, not here, so it's unaffected).

/bot-head.glb
  Cache-Control: public, max-age=2592000, immutable

/*.glb
  Cache-Control: public, max-age=2592000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=604800

/apple-touch-icon.png
  Cache-Control: public, max-age=604800

/slot-visuals.js
  Cache-Control: public, max-age=3600
/depth-visuals.js
  Cache-Control: public, max-age=3600
/support.js
  Cache-Control: public, max-age=3600
/robot-heads.js
  Cache-Control: public, max-age=3600

/*.html
  Cache-Control: public, max-age=0, must-revalidate
